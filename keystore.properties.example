# Copy this file to keystore.properties and fill in your release signing credentials.
# keystore.properties is excluded from VCS (see .gitignore) — never commit it.
#
# To generate a keystore:
#   keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias animaquiz
#
storeFile=../keystore/release.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=animaquiz
keyPassword=YOUR_KEY_PASSWORD
